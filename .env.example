# Copy this file to `.env` and fill in your actual values.
# `.env` is gitignored — never commit it.

# === Teacher LLMs (free tiers) ===
# Primary: Google AI Studio - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Backup: Groq Cloud - https://console.groq.com/keys
GROQ_API_KEY=

# === Hugging Face ===
# Settings -> Access Tokens -> create one with `write` scope
# https://huggingface.co/settings/tokens
HF_TOKEN=

# === Production GPU inference (Week 4) ===
# https://modal.com/settings/tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# === Chess data sources (no auth required for public games) ===
# Used only as a personal test set — public datasets are used for training.
LICHESS_USERNAME=
CHESSCOM_USERNAME=

# === Local paths (defaults work, override only if needed) ===
STOCKFISH_PATH=/opt/homebrew/bin/stockfish
DATA_DIR=./data
MODELS_DIR=./data/models
HF_HOME=./.hf-cache

# === Defaults for the data + training pipeline ===
STOCKFISH_DEPTH=20
STOCKFISH_MULTIPV=3
TEACHER_MODEL=gemini-2.5-flash
BASE_MODEL=mlx-community/Qwen2.5-3B-Instruct-4bit
MAX_SEQ_LEN=1024
LORA_RANK=8
LORA_ALPHA=16
LEARNING_RATE=2e-4
TRAIN_ITERS=2000
